@import url("https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Inter:wght@300;400;500;600&display=swap");

:root {
  --bg-primary: #0a0e1a;
  --bg-secondary: #0f1628;
  --bg-card: #131c30;
  --bg-card-hover: #172035;
  --bg-input: #0d1422;
  --border: #1e2d4a;
  --border-bright: #2a3f66;
  --accent-blue: #3b82f6;
  --accent-cyan: #06b6d4;
  --accent-green: #10b981;
  --accent-yellow: #f59e0b;
  --accent-red: #ef4444;
  --accent-purple: #8b5cf6;
  --text-primary: #e2e8f0;
  --text-secondary: #64748b;
  --text-muted: #334155;
  --glow-blue: rgba(59, 130, 246, 0.15);
  --glow-cyan: rgba(6, 182, 212, 0.15);
  --glow-green: rgba(16, 185, 129, 0.1);
  --glow-red: rgba(239, 68, 68, 0.1);
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  font-family: "Inter", sans-serif;
  background: var(--bg-primary);
  color: var(--text-primary);
  min-height: 100vh;
}

body::before {
  content: "";
  position: fixed;
  inset: 0;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 2px,
    rgba(0, 0, 0, 0.03) 2px,
    rgba(0, 0, 0, 0.03) 4px
  );
  pointer-events: none;
  z-index: 1000;
}

/* TOPBAR */
.topbar {
  background: var(--bg-secondary);
  border-bottom: 1px solid var(--border);
  padding: 0 2rem;
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 100;
}
.topbar-left {
  display: flex;
  align-items: center;
  gap: 12px;
}
.logo-icon {
  width: 32px;
  height: 32px;
  background: linear-gradient(135deg, var(--accent-blue), var(--accent-cyan));
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
}
.logo-text {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: 0.05em;
  text-transform: uppercase;
}
.logo-sub {
  font-size: 11px;
  color: var(--text-secondary);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-left: 4px;
  border-left: 1px solid var(--border-bright);
  padding-left: 12px;
}
.topbar-right {
  display: flex;
  align-items: center;
  gap: 16px;
  font-size: 12px;
  font-family: "JetBrains Mono", monospace;
  color: var(--text-secondary);
}
.status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--accent-green);
  box-shadow: 0 0 8px var(--accent-green);
  animation: pulse-green 2s infinite;
}
@keyframes pulse-green {
  0%,
  100% {
    opacity: 1;
  }
  50% {
    opacity: 0.4;
  }
}

/* MAIN */
.main {
  padding: 1.5rem 2rem;
  max-width: 1400px;
  margin: 0 auto;
}

/* SECTION TITLE */
.section-title {
  font-size: 11px;
  font-weight: 600;
  color: var(--accent-cyan);
  text-transform: uppercase;
  letter-spacing: 0.12em;
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.section-title::after {
  content: "";
  flex: 1;
  height: 1px;
  background: var(--border);
}
.section-num {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: var(--accent-cyan);
  color: #000;
  font-size: 11px;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* CARD */
.card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 1.25rem;
  margin-bottom: 1rem;
  position: relative;
  overflow: hidden;
}
.card::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(
    90deg,
    transparent,
    var(--accent-blue),
    transparent
  );
  opacity: 0.5;
}
.card-corner {
  position: absolute;
  top: 10px;
  right: 14px;
  font-size: 10px;
  color: var(--text-muted);
  font-family: "JetBrains Mono", monospace;
  letter-spacing: 0.1em;
}

/* FORM */
label {
  display: block;
  font-size: 11px;
  font-weight: 600;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 8px;
}
input[type="text"] {
  width: 100%;
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 10px 14px;
  font-size: 13px;
  font-family: "JetBrains Mono", monospace;
  color: var(--text-primary);
  height: 40px;
  transition: border-color 0.2s;
}
input[type="text"]:focus {
  outline: none;
  border-color: var(--accent-blue);
  box-shadow: 0 0 0 3px var(--glow-blue);
}
textarea {
  width: 100%;
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 12px 14px;
  font-size: 12px;
  font-family: "JetBrains Mono", monospace;
  color: var(--text-primary);
  resize: vertical;
  min-height: 100px;
  line-height: 1.6;
  transition: border-color 0.2s;
}
textarea:focus {
  outline: none;
  border-color: var(--accent-blue);
  box-shadow: 0 0 0 3px var(--glow-blue);
}
select {
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 8px 14px;
  font-size: 12px;
  color: var(--text-primary);
  height: 40px;
  cursor: pointer;
  transition: border-color 0.2s;
  width: 100%;
  font-family: "Inter", sans-serif;
}
select:focus {
  outline: none;
  border-color: var(--accent-blue);
}

/* BUTTONS */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 0 18px;
  height: 40px;
  font-size: 13px;
  font-weight: 500;
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.2s;
  border: 1px solid var(--border);
  background: var(--bg-card);
  color: var(--text-primary);
  font-family: "Inter", sans-serif;
  white-space: nowrap;
}
.btn:hover {
  background: var(--bg-card-hover);
  border-color: var(--border-bright);
}
.btn:active {
  transform: scale(0.97);
}
.btn-primary {
  background: var(--accent-blue);
  border-color: var(--accent-blue);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 0 20px rgba(59, 130, 246, 0.3);
}
.btn-primary:hover {
  background: #2563eb;
  border-color: #2563eb;
  box-shadow: 0 0 30px rgba(59, 130, 246, 0.5);
}
.btn-cyan {
  background: rgba(6, 182, 212, 0.15);
  border-color: var(--accent-cyan);
  color: var(--accent-cyan);
}
.btn-cyan:hover {
  background: rgba(6, 182, 212, 0.25);
}
.btn-green {
  background: rgba(16, 185, 129, 0.15);
  border-color: var(--accent-green);
  color: var(--accent-green);
}
.btn-green:hover {
  background: rgba(16, 185, 129, 0.25);
}
.btn-red {
  background: rgba(239, 68, 68, 0.12);
  border-color: var(--accent-red);
  color: var(--accent-red);
}
.btn-red:hover {
  background: rgba(239, 68, 68, 0.25);
}
.btn-abort {
  background: rgba(239, 68, 68, 0.15);
  border-color: var(--accent-red);
  color: var(--accent-red);
}
.btn-sm {
  height: 32px;
  padding: 0 14px;
  font-size: 12px;
}
.btn-xs {
  height: 26px;
  padding: 0 10px;
  font-size: 11px;
  border-radius: 6px;
}
.btn-icon {
  width: 40px;
  padding: 0;
  justify-content: center;
  font-size: 16px;
}
.btn-icon-sm {
  width: 32px;
  height: 32px;
  padding: 0;
  justify-content: center;
  font-size: 14px;
  border-radius: 6px;
}

/* GRID */
.grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}
.grid-3 {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 1rem;
}

/* PROGRESS */
.progress-bar {
  height: 4px;
  background: var(--border);
  border-radius: 2px;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent-blue), var(--accent-cyan));
  border-radius: 2px;
  transition: width 0.3s;
  box-shadow: 0 0 8px var(--accent-cyan);
}
.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
  font-size: 12px;
  font-family: "JetBrains Mono", monospace;
}
.progress-ip {
  font-size: 11px;
  color: var(--text-secondary);
  font-family: "JetBrains Mono", monospace;
  margin-top: 6px;
}

/* SPINNER */
.spinner {
  display: inline-block;
  width: 14px;
  height: 14px;
  border: 2px solid var(--border-bright);
  border-top-color: var(--accent-blue);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* TABS */
.tabs {
  display: flex;
  gap: 2px;
  border-bottom: 1px solid var(--border);
  margin-bottom: 1.25rem;
}
.tab {
  padding: 10px 18px;
  font-size: 12px;
  font-weight: 500;
  border: none;
  background: none;
  color: var(--text-secondary);
  cursor: pointer;
  border-bottom: 2px solid transparent;
  margin-bottom: -1px;
  transition: all 0.2s;
  font-family: "Inter", sans-serif;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.tab:hover {
  color: var(--text-primary);
}
.tab.active {
  color: var(--accent-cyan);
  border-bottom-color: var(--accent-cyan);
}

/* TABLE */
.table-wrap {
  overflow-x: auto;
}
table {
  width: 100%;
  border-collapse: collapse;
  font-size: 12px;
}
thead tr {
  border-bottom: 1px solid var(--border);
}
th {
  font-size: 10px;
  font-weight: 600;
  color: var(--text-secondary);
  text-align: left;
  padding: 10px 12px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  white-space: nowrap;
}
td {
  padding: 9px 12px;
  border-bottom: 1px solid rgba(30, 45, 74, 0.5);
  color: var(--text-primary);
  font-family: "JetBrains Mono", monospace;
  font-size: 11px;
}
tbody tr:hover td {
  background: var(--bg-card-hover);
}
tbody tr:last-child td {
  border-bottom: none;
}

/* BADGES */
.badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px 10px;
  border-radius: 20px;
  font-size: 11px;
  font-weight: 600;
  font-family: "JetBrains Mono", monospace;
}
.badge::before {
  content: "";
  width: 5px;
  height: 5px;
  border-radius: 50%;
}
.badge-low {
  background: rgba(16, 185, 129, 0.12);
  color: #34d399;
  border: 1px solid rgba(16, 185, 129, 0.25);
}
.badge-low::before {
  background: #10b981;
}
.badge-mid {
  background: rgba(245, 158, 11, 0.12);
  color: #fbbf24;
  border: 1px solid rgba(245, 158, 11, 0.25);
}
.badge-mid::before {
  background: #f59e0b;
}
.badge-high {
  background: rgba(239, 68, 68, 0.12);
  color: #f87171;
  border: 1px solid rgba(239, 68, 68, 0.25);
  animation: glow-red 2s infinite;
}
.badge-high::before {
  background: var(--accent-red);
}
@keyframes glow-red {
  0%,
  100% {
    box-shadow: none;
  }
  50% {
    box-shadow: 0 0 8px rgba(239, 68, 68, 0.3);
  }
}
.badge-br {
  background: rgba(59, 130, 246, 0.12);
  color: #60a5fa;
  border: 1px solid rgba(59, 130, 246, 0.25);
}
.badge-br::before {
  background: var(--accent-blue);
}
.badge-akamai {
  background: rgba(245, 158, 11, 0.15);
  color: #fbbf24;
  border: 1px solid rgba(245, 158, 11, 0.4);
  font-weight: 700;
}
.badge-akamai::before {
  background: #f59e0b;
}
.badge-internal {
  background: rgba(139, 92, 246, 0.15);
  color: #a78bfa;
  border: 1px solid rgba(139, 92, 246, 0.4);
}
.badge-internal::before {
  background: #8b5cf6;
}
.ip-list-item.is-akamai {
  border-left: 3px solid #f59e0b;
  opacity: 0.75;
}
.ip-list-item.is-internal {
  border-left: 3px solid #8b5cf6;
  opacity: 0.75;
}
.protected-warning {
  display: flex;
  align-items: center;
  gap: 8px;
  background: rgba(245, 158, 11, 0.08);
  border: 1px solid rgba(245, 158, 11, 0.3);
  border-radius: 8px;
  padding: 10px 14px;
  margin-bottom: 8px;
  font-size: 12px;
  color: #fbbf24;
  font-family: "JetBrains Mono", monospace;
}

/* OUTPUT */
.output-area {
  background: #060910;
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 16px;
  font-family: "JetBrains Mono", monospace;
  font-size: 11px;
  line-height: 1.7;
  color: #a5f3fc;
  max-height: 260px;
  overflow-y: auto;
  white-space: pre;
}
.output-area::-webkit-scrollbar {
  width: 6px;
}
.output-area::-webkit-scrollbar-track {
  background: transparent;
}
.output-area::-webkit-scrollbar-thumb {
  background: var(--border-bright);
  border-radius: 3px;
}
.output-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}
.output-label {
  font-size: 11px;
  color: var(--text-secondary);
  font-family: "JetBrains Mono", monospace;
}

/* FILTER ROW */
.filter-row {
  display: flex;
  gap: 12px;
  align-items: center;
  margin-bottom: 1rem;
  flex-wrap: wrap;
  padding: 10px 14px;
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: 8px;
}
.checkbox-label {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: var(--text-secondary);
  cursor: pointer;
  user-select: none;
  transition: color 0.2s;
}
.checkbox-label:hover {
  color: var(--text-primary);
}
.checkbox-label input[type="checkbox"] {
  width: 14px;
  height: 14px;
  accent-color: var(--accent-blue);
  cursor: pointer;
}
.divider {
  width: 1px;
  height: 20px;
  background: var(--border);
}

/* STATUS */
.status-block {
  color: var(--accent-green);
  font-size: 11px;
}
.status-br {
  color: var(--accent-blue);
  font-size: 11px;
}
.status-risk {
  color: var(--accent-red);
  font-size: 11px;
}

/* METRICS */
.metrics-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
  margin-bottom: 1rem;
}
.metric-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 1rem 1.25rem;
}
.metric-card.blue {
  border-left: 3px solid var(--accent-blue);
}
.metric-card.red {
  border-left: 3px solid var(--accent-red);
}
.metric-card.cyan {
  border-left: 3px solid var(--accent-cyan);
}
.metric-card.green {
  border-left: 3px solid var(--accent-green);
}
.metric-label {
  font-size: 11px;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 8px;
  font-weight: 500;
}
.metric-value {
  font-size: 30px;
  font-weight: 600;
  font-family: "JetBrains Mono", monospace;
  line-height: 1;
}
.metric-card.blue .metric-value {
  color: var(--accent-blue);
}
.metric-card.red .metric-value {
  color: var(--accent-red);
}
.metric-card.cyan .metric-value {
  color: var(--accent-cyan);
}
.metric-card.green .metric-value {
  color: var(--accent-green);
}
.metric-sub {
  font-size: 11px;
  color: var(--text-secondary);
  margin-top: 4px;
}

/* HIDDEN */
.hidden {
  display: none !important;
}

/* SCROLLBAR */
::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}
::-webkit-scrollbar-track {
  background: var(--bg-primary);
}
::-webkit-scrollbar-thumb {
  background: var(--border-bright);
  border-radius: 4px;
}

/* ── SECTION 1 — IP ÚNICO ── */
.attack-row {
  display: flex;
  gap: 8px;
  align-items: flex-end;
}
.attack-select-wrap {
  flex: 1;
}
.add-attack-row {
  display: flex;
  gap: 8px;
  margin-top: 8px;
  align-items: center;
}
.add-attack-input {
  flex: 1;
  height: 36px;
  font-size: 12px;
}
.ip-result-card {
  background: var(--bg-input);
  border: 1px solid var(--border-bright);
  border-radius: 10px;
  padding: 1rem 1.25rem;
  margin-top: 1rem;
  display: none;
}
.ip-result-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
  margin-bottom: 12px;
  flex-wrap: wrap;
}
.ip-result-item {
}
.ip-result-label {
  font-size: 10px;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 4px;
}
.ip-result-value {
  font-size: 13px;
  font-family: "JetBrains Mono", monospace;
  color: var(--text-primary);
}
.ip-cmd-box {
  background: #060910;
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 10px 14px;
  font-family: "JetBrains Mono", monospace;
  font-size: 11px;
  color: #a5f3fc;
  white-space: pre-wrap;
  word-break: break-all;
  margin-top: 10px;
}

/* ── SECTION 2 — PRINT ── */
.dropzone {
  border: 2px dashed var(--border-bright);
  border-radius: 12px;
  padding: 2.5rem;
  text-align: center;
  cursor: pointer;
  transition: all 0.2s;
  position: relative;
  background: var(--bg-input);
}
.dropzone:hover,
.dropzone.dragover {
  border-color: var(--accent-cyan);
  background: rgba(6, 182, 212, 0.05);
}
.dropzone-icon {
  font-size: 36px;
  margin-bottom: 12px;
}
.dropzone-text {
  font-size: 14px;
  color: var(--text-secondary);
  margin-bottom: 6px;
}
.dropzone-sub {
  font-size: 12px;
  color: var(--text-muted);
}
.dropzone input[type="file"] {
  position: absolute;
  inset: 0;
  opacity: 0;
  cursor: pointer;
}
.img-preview {
  max-width: 100%;
  max-height: 300px;
  border-radius: 8px;
  border: 1px solid var(--border);
  margin-top: 12px;
  display: none;
}
.ocr-results-list {
  margin-top: 12px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.ocr-item {
  display: flex;
  align-items: center;
  gap: 10px;
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 8px 12px;
  font-family: "JetBrains Mono", monospace;
  font-size: 12px;
}
.ocr-item-ip {
  color: var(--accent-cyan);
  min-width: 130px;
}
.ocr-item-prot {
  color: var(--text-secondary);
  flex: 1;
  font-size: 11px;
}
.ocr-item-status {
  font-size: 11px;
  min-width: 70px;
  text-align: right;
}

/* ── PROTECTED IPs ── */
.badge-protected {
  background: rgba(245, 158, 11, 0.15);
  color: #fbbf24;
  border: 1px solid rgba(245, 158, 11, 0.4);
  font-size: 11px;
  font-weight: 700;
  padding: 3px 10px;
  border-radius: 20px;
  font-family: "JetBrains Mono", monospace;
  display: inline-flex;
  align-items: center;
  gap: 4px;
}
.badge-protected::before {
  content: "";
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: #f59e0b;
}
.badge-internal {
  background: rgba(139, 92, 246, 0.15);
  color: #a78bfa;
  border: 1px solid rgba(139, 92, 246, 0.4);
  font-size: 11px;
  font-weight: 700;
  padding: 3px 10px;
  border-radius: 20px;
  font-family: "JetBrains Mono", monospace;
  display: inline-flex;
  align-items: center;
  gap: 4px;
}
.badge-internal::before {
  content: "";
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: #8b5cf6;
}
.ip-list-item.is-protected {
  border-left: 3px solid #f59e0b;
  background: rgba(245, 158, 11, 0.04);
}
.ip-list-item.is-internal {
  border-left: 3px solid #8b5cf6;
  background: rgba(139, 92, 246, 0.04);
}
.protected-warning {
  background: rgba(245, 158, 11, 0.08);
  border: 1px solid rgba(245, 158, 11, 0.3);
  border-radius: 8px;
  padding: 10px 14px;
  margin-bottom: 1rem;
  font-size: 12px;
  color: #fbbf24;
  display: flex;
  align-items: flex-start;
  gap: 10px;
}
.protected-warning strong {
  display: block;
  margin-bottom: 4px;
  font-size: 13px;
}

/* ── SECTION 2 — INPUT TABS ── */
.sec2-tabs {
  display: flex;
  gap: 4px;
  margin-bottom: 1rem;
}
.sec2-tab {
  padding: 7px 16px;
  font-size: 12px;
  font-weight: 500;
  border-radius: 8px;
  border: 1px solid var(--border);
  background: transparent;
  color: var(--text-secondary);
  cursor: pointer;
  transition: all 0.2s;
  font-family: "Inter", sans-serif;
}
.sec2-tab:hover {
  color: var(--text-primary);
  border-color: var(--border-bright);
}
.sec2-tab.active {
  background: rgba(6, 182, 212, 0.12);
  border-color: var(--accent-cyan);
  color: var(--accent-cyan);
}
.sec2-panel {
}

/* ── SECTION 3 — LISTA ── */
.ip-list-item {
  display: grid;
  grid-template-columns: 26px 130px 70px 160px 90px 70px 1fr 36px;
  gap: 8px;
  align-items: center;
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 8px 12px;
  margin-bottom: 6px;
  font-family: "JetBrains Mono", monospace;
  font-size: 11px;
  transition: border-color 0.2s;
}
.ip-list-item:hover {
  border-color: var(--border-bright);
}
.ip-list-item.is-br {
  border-left: 3px solid var(--accent-blue);
  opacity: 0.6;
}
.ip-list-item.is-high {
  border-left: 3px solid var(--accent-red);
}
.item-num {
  color: var(--text-muted);
  font-size: 10px;
  text-align: center;
}
.item-ip {
  color: var(--accent-cyan);
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.item-country {
  color: var(--text-secondary);
}
.item-isp {
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 10px;
}
.item-prot {
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 10px;
}
.item-remove {
  width: 28px;
  height: 28px;
  border-radius: 6px;
  border: 1px solid rgba(239, 68, 68, 0.3);
  background: transparent;
  color: var(--accent-red);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  transition: all 0.2s;
  padding: 0;
}
.item-remove:hover {
  background: rgba(239, 68, 68, 0.2);
  border-color: var(--accent-red);
}
.list-header {
  display: grid;
  grid-template-columns: 26px 130px 70px 160px 90px 70px 1fr 36px;
  gap: 8px;
  padding: 6px 12px;
  margin-bottom: 6px;
  font-size: 10px;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.empty-list {
  text-align: center;
  padding: 2rem;
  color: var(--text-secondary);
  font-size: 13px;
}

@media (max-width: 900px) {
  .metrics-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  .grid-2 {
    grid-template-columns: 1fr;
  }
  .ip-list-item {
    grid-template-columns: 26px 1fr 70px 36px;
  }
  .ip-list-item > *:nth-child(3),
  .ip-list-item > *:nth-child(4),
  .ip-list-item > *:nth-child(6),
  .ip-list-item > *:nth-child(7) {
    display: none;
  }
  .list-header {
    display: none;
  }
  .main {
    padding: 1rem;
  }
}
